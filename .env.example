# Required environment variables
ECOPILOT_WEBHOOK_SECRET=your-webhook-secret-here
ECOPILOT_GITLAB_TOKEN=your-gitlab-token-here

# Optional: GitLab configuration
ECOPILOT_GITLAB_BASE_URL=https://gitlab.com/api/v4

# Optional: Cost and carbon coefficients
ECOPILOT_RUNNER_COST_PER_MIN=0.008
ECOPILOT_CARBON_KG_PER_MIN=0.02

# Optional: Anthropic/Duo integration
ECOPILOT_DUO_ANTHROPIC_URL=https://your-anthropic-endpoint
ECOPILOT_DUO_ANTHROPIC_TOKEN=your-anthropic-token
ECOPILOT_DUO_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: GCP integration
ECOPILOT_GCP_PROJECT_ID=your-gcp-project-id
ECOPILOT_BIGQUERY_TABLE_ID=your-project.ecopilot.analysis_events
ECOPILOT_GCP_BILLING_TABLE_ID=your-project.billing.gcp_export

# Optional: Features
ECOPILOT_ENABLE_AUTO_LABEL=false
ECOPILOT_ENABLE_AUTO_ISSUE=false
